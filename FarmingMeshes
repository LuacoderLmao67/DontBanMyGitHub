-- ── Farm logic ─────────────────────────────────────────
local cache, cacheTime = {}, 0
local function rebuild()
    cache = {}
    for _,v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local n = v.Name:lower()
            if n:match("^energy") or n=="hat" or n=="barm4" or n=="armor"
            or n=="combine_monitor002" or n:match("combinelight") or n=="broken trancing device"
            or n=="x-18 cube" or n:match("^x%-18") then
                table.insert(cache, v)
            end
        elseif v:IsA("Model") then
            local n = v.Name:lower()
            if n:match("^memorypiece#[1-8]$") or n=="broken trancing device" or n=="x-18 cube" or n:match("^x%-18") then
                local p = v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart",true)
                if p then table.insert(cache, p) end
            end
        end
    end
end
local function closest()
    if tick()-cacheTime > 2 then rebuild(); cacheTime=tick() end
    local best, bd = nil, math.huge
    for _,v in ipairs(cache) do
        if v and v.Parent and not collected[v] then
            local n = v.Name:lower(); local pn = (v.Parent and v.Parent.Name:lower()) or ""
            local ok = targetFilter[n] or targetFilter[pn]
            if not ok then for k,e in pairs(targetFilter) do if e and(n:match("^"..k) or pn:match("^"..k)) then ok=true; break end end end
            if ok then local d=(hrp.Position-v.Position).Magnitude; if d<bd then bd=d; best=v end end
        end
    end
    return best, bd
end
local function teleport(v)
    if v and hrp then hrp.CFrame=v.CFrame+Vector3.new(0,yOffset,0); collected[v]=true; tpCount=tpCount+1 end
end
local function fmt_dist(d)
    return d>=1e6 and ("%.1fM"):format(d/1e6) or d>=1000 and ("%.1fK"):format(d/1000) or math.floor(d).."u"
end
local function fmt_time(s) return ("%02d:%02d:%02d"):format(s/3600, s%3600/60, s%60) end
local function ncol() local n=0; for _ in pairs(collected) do n=n+1 end; return n end

