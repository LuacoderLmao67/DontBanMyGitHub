local function doTeleport()
    local e,d=closest()
    if e then
        teleport(e); distLbl.Text="✓  "..fmt_dist(d).."  away"; distLbl.TextColor3=C.success; ledFlash(C.success); burst(tpBtn,10,C.accent); playPing()
        showToast("Teleported · "..fmt_dist(d),C.success,"✓"); logAndRefresh("Teleported · "..fmt_dist(d),C.success); checkMilestone(ncol())
        task.delay(2.4,function() if not autoFarm then distLbl.Text="Scanning…"; distLbl.TextColor3=C.textMut end end)
    else
        distLbl.Text="No targets found"; distLbl.TextColor3=C.danger; ledFlash(C.danger)
        showToast("No targets found",C.danger,"✕"); logAndRefresh("No targets found",C.danger)
        do
            local op=tpBtn.Position
            for i=1,3 do
                task.delay(i*0.07-0.07,function() tw(tpBtn,TweenInfo.new(0.03),{Position=op+UDim2.new(0,7,0,0)}) end)
                task.delay(i*0.07-0.035,function() tw(tpBtn,TweenInfo.new(0.03),{Position=op-UDim2.new(0,7,0,0)}) end)
            end
