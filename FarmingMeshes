-- ── Theme persistence ──────────────────────────────────
local THEME_FILE = "ef_theme.txt"
local function saveTheme(idx)
    pcall(function() writefile(THEME_FILE, tostring(idx)) end)
end
local function loadSavedTheme()
    local ok, data = pcall(function() return readfile(THEME_FILE) end)
    if ok and data then
        local idx = tonumber(data)
        if idx and idx >= 1 and idx <= #THEMES then return idx end
    end
    return 1
end

local function applyTheme(idx, silent)
    activeThemeIdx = idx
    local t = THEMES[idx]
    C.accent=t.accent; C.accentBrt=t.accentB; C.accentDim=t.accentD
    C.border=t.border; C.borderBrt=t.borderB
    local ti = TweenInfo.new(0.38, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    for _,r in ipairs(themeRefs) do
        TweenService:Create(r.obj, ti, {[r.prop]=C[r.slot]}):Play()
    end
    if not silent then saveTheme(idx) end
end

