    if gp then return end
    if inp.KeyCode==Enum.KeyCode.F then doTeleport()
    elseif inp.KeyCode==Enum.KeyCode.G then doToggleAuto()
    elseif inp.KeyCode==Enum.KeyCode.H then
        panicHidden = not panicHidden
        if panicHidden then
            tw(main,    TW.closeS, {BackgroundTransparency=1, Position=UDim2.new(0.5,-MW/2,0.08,-12)})
            tw(clPanel, TW.closeS, {BackgroundTransparency=1, Position=UDim2.new(1,-CW-12+14,0,44)})
            task.delay(0.22, function() main.Visible=false; clPanel.Visible=false end)
        else
            main.Visible=true; clPanel.Visible=true
